<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymManager.MauiView.MemberDetailsPage"
             Title="بيانات العضو"
             FlowDirection="RightToLeft"
             BackgroundColor="#F6F7F9">

    <ScrollView>
        <Grid Padding="24" RowDefinitions="Auto,Auto,Auto" RowSpacing="18">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                <VerticalStackLayout Spacing="4">
                    <Label Text="بيانات العضو"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#18202B" />
                    <Label Text="{Binding MemberIdText}"
                           FontSize="14"
                           TextColor="#2563EB" />
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        BackgroundColor="{Binding StatusColorHex}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 8"
                        Padding="18,10"
                        VerticalOptions="Center">
                    <Label Text="{Binding Status}"
                           TextColor="#FFFFFF"
                           FontSize="14"
                           FontAttributes="Bold" />
                </Border>
            </Grid>

            <Border x:Name="DetailsPanel"
                    Grid.Row="1"
                    BackgroundColor="#FFFFFF"
                    Stroke="#DDE3EA"
                    StrokeShape="RoundRectangle 8"
                    Padding="22">
                <VerticalStackLayout Spacing="18">
                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="16"
                          RowSpacing="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="اسم العضو" FontSize="13" TextColor="#647084" />
                            <Label Text="{Binding Name}" FontSize="20" FontAttributes="Bold" TextColor="#18202B" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="رقم الهاتف" FontSize="13" TextColor="#647084" />
                            <Label Text="{Binding Phone}" FontSize="18" TextColor="#18202B" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Spacing="6">
                            <Label Text="نوع الاشتراك" FontSize="13" TextColor="#647084" />
                            <Label Text="{Binding Plan}" FontSize="18" TextColor="#18202B" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                            <Label Text="حالة الاشتراك" FontSize="13" TextColor="#647084" />
                            <Label Text="{Binding RemainingDaysText}" FontSize="18" TextColor="#18202B" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="2" Spacing="6">
                            <Label Text="تاريخ البداية" FontSize="13" TextColor="#647084" />
                            <Label Text="{Binding StartDateText}" FontSize="16" TextColor="#18202B" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="6">
                            <Label Text="تاريخ الانتهاء" FontSize="13" TextColor="#647084" />
                            <Label Text="{Binding EndDateText}" FontSize="16" TextColor="#18202B" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#E6EBF1" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="معلومات النظام" FontSize="13" TextColor="#647084" />
                        <Label Text="{Binding CreatedAtText}" FontSize="16" TextColor="#18202B" />
                        <Label Text="{Binding CanceledAtText}" FontSize="16" TextColor="#6B7280" />
                        <Label x:Name="TotalAttendanceLabel"
                               Text="إجمالي أيام الحضور: 0"
                               FontSize="16"
                               TextColor="#2563EB" />
                    </VerticalStackLayout>

                    <Button x:Name="CancelMembershipButton"
                            Text="إلغاء العضوية"
                            BackgroundColor="#C2410C"
                            TextColor="#FFFFFF"
                            CornerRadius="6"
                            IsVisible="{Binding CanCancelMembership}"
                            Clicked="OnCancelMembershipClicked" />

                    <Button Text="رجوع"
                            BackgroundColor="#2563EB"
                            TextColor="#FFFFFF"
                            CornerRadius="6"
                            Clicked="OnBackClicked" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="AttendancePanel"
                    Grid.Row="2"
                    BackgroundColor="#FFFFFF"
                    Stroke="#DDE3EA"
                    StrokeShape="RoundRectangle 8"
                    Padding="22">
                <Grid RowDefinitions="Auto,*" RowSpacing="14">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="سجل الحضور"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#18202B" />
                            <Label Text="تواريخ وأوقات حضور العضو."
                                   FontSize="13"
                                   TextColor="#647084" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="1"
                                              Spacing="6"
                                              VerticalOptions="Center"
                                              HorizontalOptions="End">
                            <Label Text="السنة"
                                   FontSize="13"
                                   TextColor="#647084"
                                   VerticalOptions="Center" />
                            <Picker x:Name="YearPicker"
                                    FontSize="12"
                                    HeightRequest="32"
                                    TextColor="#000000"
                                    TitleColor="#7B8794"
                                    BackgroundColor="#F8FAFC"
                                    SelectedIndexChanged="OnFilterChanged" />

                            <Label Text="الشهر"
                                   FontSize="13"
                                   TextColor="#647084"
                                   VerticalOptions="Center" />
                            <Picker x:Name="MonthPicker"
                                    FontSize="12"
                                    HeightRequest="32"
                                    TextColor="#000000"
                                    TitleColor="#7B8794"
                                    BackgroundColor="#F8FAFC"
                                    SelectedIndexChanged="OnFilterChanged" />

                            <Label Text="اليوم"
                                   FontSize="13"
                                   TextColor="#647084"
                                   VerticalOptions="Center" />
                            <Picker x:Name="DayPicker"
                                    FontSize="12"
                                    HeightRequest="32"
                                    TextColor="#000000"
                                    TitleColor="#7B8794"
                                    BackgroundColor="#F8FAFC"
                                    SelectedIndexChanged="OnFilterChanged" />

                            <Button Text="✕"
                                    FontSize="12"
                                    Padding="6,2"
                                    HeightRequest="32"
                                    WidthRequest="32"
                                    BackgroundColor="#C2410C"
                                    TextColor="#FFFFFF"
                                    CornerRadius="4"
                                    VerticalOptions="Center"
                                    Clicked="OnClearFiltersClicked" />
                        </HorizontalStackLayout>
                    </Grid>

                    <CollectionView Grid.Row="1"
                                    x:Name="AttendanceHistoryCollection"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Grid Padding="24">
                                <Label Text="لا يوجد سجل حضور لهذا العضو."
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="#647084" />
                            </Grid>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#E6EBF1"
                                        StrokeShape="RoundRectangle 6"
                                        Padding="12"
                                        Margin="0,0,0,8"
                                        BackgroundColor="#F8FAFC">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding AttendDateTime, StringFormat='{0:dd MMMM yyyy - hh:mm tt}'}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="#18202B" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="1"
                                                BackgroundColor="#2563EB"
                                                Stroke="Transparent"
                                                StrokeShape="RoundRectangle 4"
                                                Padding="8,4"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding PlayType}"
                                                   TextColor="#FFFFFF"
                                                   FontSize="11" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Border x:Name="NotFoundPanel"
                    Grid.Row="1"
                    IsVisible="False"
                    BackgroundColor="#FFFFFF"
                    Stroke="#DDE3EA"
                    StrokeShape="RoundRectangle 8"
                    Padding="24">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="لم يتم العثور على العضو"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#18202B"
                           HorizontalTextAlignment="Center" />
                    <Button Text="رجوع"
                            BackgroundColor="#2563EB"
                            TextColor="#FFFFFF"
                            CornerRadius="6"
                            Clicked="OnBackClicked" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
