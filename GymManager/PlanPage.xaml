<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymManager.MauiView.PlanPage"
             Title="الخطط"
             FlowDirection="RightToLeft"
             BackgroundColor="#F6F7F9">

    <ContentPage.Resources>
        <Style x:Key="FormInputStyle" TargetType="Entry">
            <Setter Property="TextColor" Value="#000000" />
            <Setter Property="PlaceholderColor" Value="#7B8794" />
            <Setter Property="BackgroundColor" Value="#F8FAFC" />
            <Setter Property="HeightRequest" Value="46" />
            <Setter Property="HorizontalTextAlignment" Value="Start" />
        </Style>

        <Style x:Key="FormPickerStyle" TargetType="Picker">
            <Setter Property="TextColor" Value="#000000" />
            <Setter Property="TitleColor" Value="#7B8794" />
            <Setter Property="BackgroundColor" Value="#F8FAFC" />
            <Setter Property="HeightRequest" Value="65" />
            <Setter Property="HorizontalTextAlignment" Value="Start" />
        </Style>

        <Style x:Key="FormEditorStyle" TargetType="Editor">
            <Setter Property="TextColor" Value="#000000" />
            <Setter Property="PlaceholderColor" Value="#7B8794" />
            <Setter Property="BackgroundColor" Value="#F8FAFC" />
            <Setter Property="HeightRequest" Value="80" />
            <Setter Property="HorizontalTextAlignment" Value="Start" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" Padding="24" RowSpacing="18">
        <Label Text="الخطط"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="#18202B" />

        <Grid Grid.Row="1"
              ColumnDefinitions="340,*"
              RowDefinitions="Auto,*"
              ColumnSpacing="18"
              RowSpacing="18">
            <Border Grid.Row="1"
                    BackgroundColor="#FFFFFF"
                    Stroke="#DDE3EA"
                    StrokeShape="RoundRectangle 8"
                    Padding="18">
                <ScrollView>
                    <VerticalStackLayout Spacing="14">
                        <Label x:Name="FormTitle"
                               Text="إضافة خطة"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#18202B" />

                        <Entry x:Name="PlanNameEntry"
                               Placeholder="اسم الخطة"
                               Style="{StaticResource FormInputStyle}" />

                        <Editor x:Name="PlanDescriptionEditor"
                                Placeholder="وصف الخطة"
                                Style="{StaticResource FormEditorStyle}" />

                        <Entry x:Name="PlanPriceEntry"
                               Placeholder="السعر"
                               Style="{StaticResource FormInputStyle}"
                               Keyboard="Numeric" />

                        <Picker x:Name="PlanTypePicker"
                                Title="نوع الخطة"
                                Style="{StaticResource FormPickerStyle}" />

                        <Picker x:Name="PeriodPicker"
                                Title="المدة"
                                Style="{StaticResource FormPickerStyle}" />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Button x:Name="SaveButton"
                                    Text="إضافة"
                                    BackgroundColor="#2563EB"
                                    TextColor="#FFFFFF"
                                    CornerRadius="6"
                                    Clicked="OnSavePlanClicked" />

                            <Button x:Name="CancelButton"
                                    Grid.Column="1"
                                    Text="إلغاء"
                                    BackgroundColor="#6B7280"
                                    TextColor="#FFFFFF"
                                    CornerRadius="6"
                                    IsVisible="False"
                                    Clicked="OnCancelEditClicked" />
                        </Grid>

                        <Label x:Name="FormMessageLabel"
                               TextColor="#C2410C"
                               FontSize="13" />
                    </VerticalStackLayout>
                </ScrollView>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    BackgroundColor="#FFFFFF"
                    Stroke="#DDE3EA"
                    StrokeShape="RoundRectangle 8"
                    Padding="18">
                <Grid RowDefinitions="Auto,*" RowSpacing="14">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="الخطط"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#18202B" />
                        <Label Text="قائمة بالخطط السعرية."
                               FontSize="13"
                               TextColor="#647084" />
                    </VerticalStackLayout>

                    <CollectionView x:Name="PlansCollection"
                                    Grid.Row="1"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Grid Padding="24">
                                <Label Text="لا توجد خطط حتى الآن."
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="#647084" />
                            </Grid>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#E6EBF1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        BackgroundColor="#FFFFFF">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Name}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="#18202B" />
                                                <Label Text="{Binding Description}"
                                                       FontSize="13"
                                                       TextColor="#647084"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <Border Grid.Column="1"
                                                    BackgroundColor="{Binding StatusColorHex}"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 6"
                                                    Padding="8,6"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding Status}"
                                                       TextColor="#FFFFFF"
                                                       FontSize="11" />
                                            </Border>

                                            <Label Grid.Column="2"
                                                   Text="{Binding PriceText, StringFormat='{0} ج.م'}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="#2563EB"
                                                   VerticalOptions="Center" />
                                        </Grid>

                                        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <Label Text="{Binding PlanTypeName, StringFormat='النوع: {0}'}"
                                                   FontSize="13"
                                                   TextColor="#647084" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding PeriodName, StringFormat='المدة: {0}'}"
                                                   FontSize="13"
                                                   TextColor="#647084" />
                                        </Grid>

                                        <BoxView Grid.Row="2" HeightRequest="1" Color="#E6EBF1" />

                                        <HorizontalStackLayout Grid.Row="3" Spacing="6">
                                            <Button Text="تعديل"
                                                    FontSize="11"
                                                    Padding="8,4"
                                                    BackgroundColor="#2563EB"
                                                    TextColor="#FFFFFF"
                                                    CornerRadius="4"
                                                    HeightRequest="30"
                                                    Clicked="OnEditPlanClicked" />

                                            <Button Text="نسخ"
                                                    FontSize="11"
                                                    Padding="8,4"
                                                    BackgroundColor="#B7791F"
                                                    TextColor="#FFFFFF"
                                                    CornerRadius="4"
                                                    HeightRequest="30"
                                                    Clicked="OnDuplicatePlanClicked" />

                                            <Button Text="تعطيل"
                                                    FontSize="11"
                                                    Padding="8,4"
                                                    BackgroundColor="#6B7280"
                                                    TextColor="#FFFFFF"
                                                    CornerRadius="4"
                                                    HeightRequest="30"
                                                    Clicked="OnToggleStatusClicked">
                                                <Button.Triggers>
                                                    <DataTrigger TargetType="Button"
                                                                 Binding="{Binding IsActive}"
                                                                 Value="False">
                                                        <Setter Property="Text" Value="تفعيل" />
                                                        <Setter Property="BackgroundColor" Value="#22A06B" />
                                                    </DataTrigger>
                                                </Button.Triggers>
                                            </Button>

                                            <Button Text="حذف"
                                                    FontSize="11"
                                                    Padding="8,4"
                                                    BackgroundColor="#C2410C"
                                                    TextColor="#FFFFFF"
                                                    CornerRadius="4"
                                                    HeightRequest="30"
                                                    Clicked="OnDeletePlanClicked" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
