<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymManager.MauiView.AttendancePage"
             Title="سجل الحضور"
             FlowDirection="RightToLeft"
             BackgroundColor="#F6F7F9">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="18">
        <VerticalStackLayout Spacing="2">
            <Label Text="سجل الحضور"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#18202B" />
            <Label Text="متابعة حضور الأعضاء يومياً وشهرياً."
                   FontSize="14"
                   TextColor="#647084" />
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="12">
            <Border BackgroundColor="#FFFFFF" Stroke="#DDE3EA" StrokeShape="RoundRectangle 8" Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="حضور اليوم" FontSize="13" TextColor="#647084" />
                    <Label x:Name="TodayCountLabel" Text="0" FontSize="26" FontAttributes="Bold" TextColor="#2563EB" />
                </VerticalStackLayout>
            </Border>

            <Border Grid.Column="1" BackgroundColor="#FFFFFF" Stroke="#DDE3EA" StrokeShape="RoundRectangle 8" Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="حضور هذا الشهر" FontSize="13" TextColor="#647084" />
                    <Label x:Name="MonthCountLabel" Text="0" FontSize="26" FontAttributes="Bold" TextColor="#22A06B" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                BackgroundColor="#FFFFFF"
                Stroke="#DDE3EA"
                StrokeShape="RoundRectangle 8"
                Padding="18">
            <Grid RowDefinitions="Auto,*" RowSpacing="14">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="تسجيلات اليوم"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#18202B" />
                        <Label Text="الأعضاء الذين سجلوا حضورهم اليوم."
                               FontSize="13"
                               TextColor="#647084" />
                    </VerticalStackLayout>

                    <SearchBar Grid.Column="1"
                               x:Name="AttendanceSearchBar"
                               Placeholder="بحث برقم العضوية"
                               TextColor="#000000"
                               PlaceholderColor="#7B8794"
                               BackgroundColor="#F8FAFC"
                               FlowDirection="RightToLeft"
                               TextChanged="OnSearchTextChanged" />
                </Grid>

                <CollectionView Grid.Row="1"
                                x:Name="AttendanceCollection"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Grid Padding="24">
                            <Label Text="لا يوجد تسجيلات حضور اليوم."
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="#647084" />
                        </Grid>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="#E6EBF1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="14"
                                    Margin="0,0,0,10"
                                    BackgroundColor="#FFFFFF">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="4">
                                        <Label FontSize="12"
                                               TextColor="#2563EB">
                                            <Label.Text>
                                                <MultiBinding StringFormat="رقم العضوية: {0}">
                                                    <Binding Path="MemberId" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <Label Text="{Binding MemberName}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#18202B" />
                                        <Label Text="{Binding AttendDateTime, StringFormat='{0:hh:mm tt}'}"
                                               TextColor="#647084"
                                               FontSize="13" />
                                    </VerticalStackLayout>

                                    <Border Grid.Column="1"
                                            BackgroundColor="#2563EB"
                                            Stroke="Transparent"
                                            StrokeShape="RoundRectangle 6"
                                            Padding="10,6"
                                            VerticalOptions="Center">
                                        <Label Text="{Binding PlayType}"
                                               TextColor="#FFFFFF"
                                               FontSize="12" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
