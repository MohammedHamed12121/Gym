<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GymManager.MauiView.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GymManager.MauiView"
    Shell.FlyoutBehavior="Flyout"
    FlyoutWidth="280"
    FlowDirection="LeftToRight"
    Title="إدارة الجيم">

    <Shell.FlyoutHeader>
        <Grid Padding="20,22"
              BackgroundColor="#18202B"
              FlowDirection="RightToLeft">
            <VerticalStackLayout Spacing="4">
                <Label Text="إدارة الجيم"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#FFFFFF" />
                <Label Text="نظام إدارة الجيم المحلي"
                       FontSize="13"
                       TextColor="#CBD5E1" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="الرئيسية"
                Route="Home"
                FlyoutDisplayOptions="AsSingleItem">
        <ShellContent
            Title="الرئيسية"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem Title="سجل الحضور"
                Route="Attendance"
                FlyoutDisplayOptions="AsSingleItem">
        <ShellContent
            Title="سجل الحضور"
            ContentTemplate="{DataTemplate local:AttendancePage}"
            Route="AttendancePage" />
    </FlyoutItem>

    <FlyoutItem Title="أنواع الخطط"
                Route="PlanTypes"
                FlyoutDisplayOptions="AsSingleItem">
        <ShellContent
            Title="أنواع الخطط"
            ContentTemplate="{DataTemplate local:PlanTypePage}"
            Route="PlanTypePage" />
    </FlyoutItem>

    <FlyoutItem Title="الخطط"
                Route="Plans"
                FlyoutDisplayOptions="AsSingleItem">
        <ShellContent
            Title="الخطط"
            ContentTemplate="{DataTemplate local:PlanPage}"
            Route="PlanPage" />
    </FlyoutItem>

</Shell>
