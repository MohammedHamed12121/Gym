<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymManager.MauiView.PlanTypePage"
             Title="أنواع الخطط"
             FlowDirection="RightToLeft"
             BackgroundColor="#F6F7F9">

    <Grid RowDefinitions="Auto,*" Padding="24" RowSpacing="18">
        <Label Text="أنواع الخطط"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="#18202B" />

        <Grid Grid.Row="1"
              ColumnDefinitions="320,*"
              RowDefinitions="Auto,*"
              ColumnSpacing="18"
              RowSpacing="18">
            <Border Grid.Row="1"
                    BackgroundColor="#FFFFFF"
                    Stroke="#DDE3EA"
                    StrokeShape="RoundRectangle 8"
                    Padding="18">
                <ScrollView>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="إضافة نوع خطة"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#18202B" />

                        <Entry x:Name="PlanTypeNameEntry"
                               Placeholder="اسم نوع الخطة"
                               TextColor="#000000"
                               PlaceholderColor="#7B8794"
                               BackgroundColor="#F8FAFC"
                               HeightRequest="46" />

                        <Button x:Name="AddPlanTypeButton"
                                Text="إضافة"
                                BackgroundColor="#2563EB"
                                TextColor="#FFFFFF"
                                CornerRadius="6"
                                Clicked="OnAddPlanTypeClicked" />

                        <Label x:Name="FormMessageLabel"
                               TextColor="#C2410C"
                               FontSize="13" />
                    </VerticalStackLayout>
                </ScrollView>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    BackgroundColor="#FFFFFF"
                    Stroke="#DDE3EA"
                    StrokeShape="RoundRectangle 8"
                    Padding="18">
                <Grid RowDefinitions="Auto,*" RowSpacing="14">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="الأنواع"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#18202B" />
                        <Label Text="قائمة بأنواع الخطط المتاحة."
                               FontSize="13"
                               TextColor="#647084" />
                    </VerticalStackLayout>

                    <CollectionView x:Name="PlanTypesCollection"
                                    Grid.Row="1"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Grid Padding="24">
                                <Label Text="لا توجد أنواع خطط حتى الآن."
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="#647084" />
                            </Grid>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#E6EBF1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        BackgroundColor="#FFFFFF">
                                    <Grid ColumnDefinitions="*,120,150" ColumnSpacing="8">
                                        <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="#18202B" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="1"
                                                BackgroundColor="{Binding StatusColorHex}"
                                                Stroke="Transparent"
                                                StrokeShape="RoundRectangle 6"
                                                Padding="8,6"
                                                HorizontalOptions="End"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding Status}"
                                                   TextColor="#FFFFFF"
                                                   FontSize="11" />
                                        </Border>

                                        <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center" HorizontalOptions="End">
                                            <Button Text="تعطيل"
                                                    FontSize="11"
                                                    Padding="6,4"
                                                    BackgroundColor="#6B7280"
                                                    TextColor="#FFFFFF"
                                                    CornerRadius="4"
                                                    Clicked="OnToggleStatusClicked">
                                                <Button.Triggers>
                                                    <DataTrigger TargetType="Button"
                                                                 Binding="{Binding IsActive}"
                                                                 Value="False">
                                                        <Setter Property="Text" Value="تفعيل" />
                                                        <Setter Property="BackgroundColor" Value="#22A06B" />
                                                    </DataTrigger>
                                                </Button.Triggers>
                                            </Button>

                                            <Button Text="حذف"
                                                    FontSize="11"
                                                    Padding="6,4"
                                                    BackgroundColor="#C2410C"
                                                    TextColor="#FFFFFF"
                                                    CornerRadius="4"
                                                    Clicked="OnDeletePlanTypeClicked" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
